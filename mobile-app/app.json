{
  "expo": {
    "name": "Zoovita",
    "slug": "zoovita",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "light",
    "scheme": "zoovita",
    "android": {
      "package": "com.zoovita.app"
    },
    "ios": {
      "bundleIdentifier": "com.zoovita.app",
      "infoPlist": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.655058612465-r0u5aqdtl7u19ck4t78dp4v9bch3dfk5"
            ]
          },
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.655058612465-r0u5aqdtl7u19ck4t78dp4v9bch3dfk5"
            ]
          }
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#F7FBF4"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "plugins": [
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Ilovaga sizning manzilingizni aniqlash uchun ruxsat bering. Bu orqali e'loningizni tezroq va qulayroq joylashtirasiz."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "9703eb9e-d65d-43b5-8143-59dd9d629eed"
      }
    }
  }
}
